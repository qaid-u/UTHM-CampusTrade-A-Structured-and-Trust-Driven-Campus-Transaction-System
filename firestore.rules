rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Items collection
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid ||
        // Allow status updates during transaction state sync (buying/locking)
        request.resource.data.status == 'sold' ||
        request.resource.data.status == 'completed' ||
        request.resource.data.status == 'available'
      );
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // Offers collection
    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || 
        resource.data.buyerId == request.auth.uid
      );
      allow delete: if false; // Cannot delete offers, only cancel/reject
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId || 
        request.auth.uid == resource.data.sellerId || 
        request.auth.uid in resource.data.participants
      );
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.buyerId || 
        request.auth.uid == request.resource.data.sellerId
      );
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId || 
        request.auth.uid == resource.data.sellerId
      ) && (
        // Only buyer can complete transaction
        (request.resource.data.status == 'completed' && request.auth.uid == resource.data.buyerId) ||
        // Cancel can be done by either, but cannot cancel completed
        (request.resource.data.status == 'cancelled' && resource.data.status != 'completed') ||
        // Meetup confirm/update or other fields progression
        (request.resource.data.status == 'meetup_pending' || request.resource.data.status == resource.data.status)
      );
      allow delete: if false;
    }

    // Chat Rooms collection
    match /chatRooms/{roomId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.participantIds ||
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.auth.uid in request.resource.data.participantIds ||
        request.resource.data.buyerId == request.auth.uid ||
        request.resource.data.sellerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participantIds ||
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      allow delete: if false;

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds ||
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.buyerId == request.auth.uid ||
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.sellerId == request.auth.uid
        );
        allow create: if isSignedIn() 
          && (
            request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds ||
            get(/databases/$(database)/documents/chatRooms/$(roomId)).data.buyerId == request.auth.uid ||
            get(/databases/$(database)/documents/chatRooms/$(roomId)).data.sellerId == request.auth.uid
          )
          && request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() 
          && (
            request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds ||
            get(/databases/$(database)/documents/chatRooms/$(roomId)).data.buyerId == request.auth.uid ||
            get(/databases/$(database)/documents/chatRooms/$(roomId)).data.sellerId == request.auth.uid
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['offerStatus']);
        allow delete: if false;
      }
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      // Double-blind review: document name is ${transactionId}_${reviewerId}
      allow create: if isSignedIn() 
        && request.auth.uid == request.resource.data.reviewerId
        && reviewId == request.resource.data.transactionId + '_' + request.resource.data.reviewerId;
      allow update, delete: if false; // Immutable write-once reviews
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Config collection
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
